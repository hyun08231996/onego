# Docker Compose / backend variables
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_AUTH_DB=admin
MONGO_DB=onego
MONGO_USERNAME=your-mongo-username
MONGO_PASSWORD=your-mongo-password

GCP_STORAGE_BUCKET=your-gcs-bucket-name
COGNITO_ISSUER_URI=https://cognito-idp.ap-northeast-2.amazonaws.com/your-user-pool-id

HUGGINGFACE_API_KEY=your-huggingface-api-key
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct

# Frontend build-time Cognito variables
VUE_APP_AWS_REGION=ap-northeast-2
VUE_APP_COGNITO_IDENTITY_POOL_ID=ap-northeast-2:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VUE_APP_COGNITO_USER_POOL_ID=ap-northeast-2_xxxxxxxx
VUE_APP_COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
